<odoo>
    <record id="view_crm_inherit_form" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <field name="stage_id" invisible="1"/>
                <field name="is_stage_past_new" invisible="1"/>
            </xpath>
            <xpath expr="//field[@name='expected_revenue']" position="after">
                <header name="import_header">
                    <button name="%(action_customer_request_import_wizard)d"
                            string="Import Requests From Excel"
                            type="action"
                            class="btn-secondary"
                            invisible="is_stage_past_new"/>
                </header>
                <group name="customer_request_group">
                    <field name="request_ids"/>
                    <field name="sale_amount"/>
                    <field name="revenue"/>
                </group>
            </xpath>
        </field>
    </record>

    <record id="view_crm_lead_form_readonly_lock" model="ir.ui.view">
        <field name="name">crm.lead.form.readonly.lock</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form//field" position="attributes">
                <attribute name="readonly">is_stage_past_new</attribute>
            </xpath>
        </field>
    </record>
</odoo>