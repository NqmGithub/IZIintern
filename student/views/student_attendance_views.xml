<odoo>
    <record id="view_student_attendance_list" model="ir.ui.view">
        <field name="name">student.attendance.list</field>
        <field name="model">student.attendance</field>
        <field name="arch" type="xml">
            <list string="Student Attendance" editable="bottom" create="0">
                <field name="student_id"/>
                <field name="schedule_id"/>
                <field name="date"/>
                <field name="status"/>
                <field name="homework_status"/>
            </list>
        </field>
    </record>

    <record id="view_student_attendance_form" model="ir.ui.view">
        <field name="name">student.attendance.form</field>
        <field name="model">student.attendance</field>
        <field name="arch" type="xml">
            <form string="Student Attendance">
                <sheet>
                    <group>
                        <field name="student_id"/>
                        <field name="schedule_id"/>
                        <field name="date"/>
                        <field name="status"/>
                        <field name="homework_status"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_student_attendance" model="ir.actions.act_window">
        <field name="name">Student Attendance</field>
        <field name="res_model">student.attendance</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_student_attendance_search" model="ir.ui.view">
        <field name="name">student.attendance.search</field>
        <field name="model">student.attendance</field>
        <field name="arch" type="xml">
            <search string="Search Student Attendance">
                <field name="student_id" filter_domain="[('student_id', 'ilike', self)]"/>
                <field name="schedule_id" filter_domain="[('schedule_id', 'ilike', self)]"/>
                <field name="date" filter_domain="[('date', '=', self)]"/>
                <field name="status" filter_domain="[('status', 'ilike', self)]"/>
                <field name="homework_status" filter_domain="[('homework_status', 'ilike', self)]"/>
            </search>
        </field>
    </record>

    <record id="action_generate_daily_attendance" model="ir.actions.server">
        <field name="name">Generate Daily Attendance</field>
        <field name="model_id" ref="model_student_attendance"/>
        <!-- <field name="binding_model_id" ref="model_student_attendance"/>
        <field name="binding_view_types">list</field> -->
        <field name="state">code</field>
        <field name="code">
            action = model.action_generate_daily_attendance()
        </field>
    </record>

    <record id="action_attendance_status_mark_present" model="ir.actions.server">
        <field name="name">Mark as Present</field>
        <field name="model_id" ref="model_student_attendance"/>
        <field name="state">code</field>
        <field name="code">
            records.mark_as_present()
        </field>
    </record>

    <record id="action_attendance_status_mark_absent" model="ir.actions.server">
        <field name="name">Mark as Absent</field>
        <field name="model_id" ref="model_student_attendance"/>
        <field name="state">code</field>
        <field name="code">
            records.mark_as_absent()
        </field>
    </record>

    <record id="action_attendance_status_mark_late" model="ir.actions.server">
        <field name="name">Mark as Late</field>
        <field name="model_id" ref="model_student_attendance"/>
        <field name="state">code</field>
        <field name="code">
            records.mark_as_late()
        </field>
    </record>

    <record id="action_attendance_status_mark_homework_done" model="ir.actions.server">
        <field name="name">Mark Homework Done</field>
        <field name="model_id" ref="model_student_attendance"/>
        <field name="state">code</field>
        <field name="code">
            records.mark_homework_completed()
        </field>
    </record>

    <record id="action_attendance_status_mark_homework_not_completed" model="ir.actions.server">
        <field name="name">Mark Homework Not Completed</field>
        <field name="model_id" ref="model_student_attendance"/>
        <field name="state">code</field>
        <field name="code">
            records.mark_homework_not_completed()
        </field>
    </record>

    <record id="action_attendance_status_mark_homework_late" model="ir.actions.server">
        <field name="name">Mark Homework Late</field>
        <field name="model_id" ref="model_student_attendance"/>
        <field name="state">code</field>
        <field name="code">
            records.mark_homework_late()
        </field>
    </record>


    <menuitem id="menu_student_attendance" name="Student Attendance" parent="menu_student_root" action="action_student_attendance"/>
    <menuitem id="menu_generate_daily_attendance" name="Today Attendance" parent="menu_student_root" action="action_generate_daily_attendance"/>
</odoo> 