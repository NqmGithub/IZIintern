<odoo>
    <record id="view_material_learning_list" model="ir.ui.view">
        <field name="name">material.learning.list</field>
        <field name="model">material.learning</field>
        <field name="arch" type="xml">
            <list string="Material Learning">
                <field name="name"/>
                <field name="learning_level"/>
                <field name="topic_type"/>
                <field name="source"/>
            </list>
        </field>
    </record>

    <record id="view_material_learning_form" model="ir.ui.view">
        <field name="name">material.learning.form</field>
        <field name="model">material.learning</field>
        <field name="arch" type="xml">
            <form string="Material Learning">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="learning_level"/>
                        <field name="topic_type"/>
                        <field name="source"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_material_learning" model="ir.actions.act_window">
        <field name="name">Material Learning</field>
        <field name="res_model">material.learning</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem name="Material Learning" id="menu_material_learning" parent="menu_student_root" action="action_material_learning" sequence="30"/>
</odoo>