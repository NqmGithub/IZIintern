<odoo>
    <record id="view_student_class_list" model="ir.ui.view">
        <field name="name">student.class.list</field>
        <field name="model">student.class</field>
        <field name="arch" type="xml">
            <list string="Student Classes">
                <field name="class_code"/>
                <field name="class_location"/>
                <field name="class_type"/>
                <field name="student_count"/>
            </list>
        </field>
    </record>

    <record id="view_student_class_form" model="ir.ui.view">
        <field name="name">student.class.form</field>
        <field name="model">student.class</field>
        <field name="arch" type="xml">
            <form string="Student Class">
                <sheet>
                    <group>
                        <field name="class_code" readonly="1"/>
                        <field name="class_location"/>
                        <field name="class_type"/>         
                        <field name="student_count" readonly="1"/>               
                    </group>
                    <notebook>
                        <page string="Students">
                            <field name="student_selection_ids" options="{'no_create': True, 'no_open': True}"
                                domain="['|', ('class_id', '=', False), ('class_id', '=', id)]">
                                <list editable="bottom" create="false" edit="false"> 
                                    <field name="partner_id" readonly="0" />
                                    <field name="name" readonly="1"/>
                                    <field name="dob" readonly="1"/>
                                    <field name="english_experience" readonly="1"/>
                                    <field name="parents_contact" readonly="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Class Schedule">
                            <field name="class_schedule" options="{'no_create': False, 'no_open': True}">
                                <list editable="bottom">
                                    <field name="day_id" options="{'no_create': True}"/>
                                    <field name="start_time" widget="float_time"/>
                                    <field name="end_time" widget="float_time"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_student_class" model="ir.actions.act_window">
        <field name="name">Student Classes</field>
        <field name="res_model">student.class</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem name="Student Classes" id="menu_student_classes" parent="menu_student_root" action="action_student_class" sequence="20"/>
</odoo>