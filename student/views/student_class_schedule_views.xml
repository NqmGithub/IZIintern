<odoo>
    <record id="view_student_class_schedule_list" model="ir.ui.view">
        <field name="name">student.class.schedule.list</field>
        <field name="model">student.class.schedule</field>
        <field name="arch" type="xml">
            <list string="Student Class Schedule">
                <field name="class_id"/>
                <field name="day_id"/>
                <field name="start_time" widget="float_time"/>
                <field name="end_time" widget="float_time"/>
            </list>
        </field>
    </record>

    <record id="view_student_class_schedule_form" model="ir.ui.view">
        <field name="name">student.class.schedule.form</field>
        <field name="model">student.class.schedule</field>
        <field name="arch" type="xml">
            <form string="Student Class Schedule">
                <sheet>
                    <group>
                        <field name="class_id"/>
                        <field name="day_id" options="{'no_create': True}"/>
                        <field name="start_time" widget="float_time"/>
                        <field name="end_time" widget="float_time"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_student_class_schedule" model="ir.actions.act_window">
        <field name="name">Student Class Schedule</field>
        <field name="res_model">student.class.schedule</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_student_class_schedule" name="Student Class Schedule" parent="menu_student_root" action="action_student_class_schedule"/>
</odoo>