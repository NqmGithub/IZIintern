<odoo>
    <data noupdate="1">
        <record id="cron_check_student_count" model="ir.cron">
            <field name="name">Student: Check Student Count</field>
            <field name="model_id" ref="model_student_class"/>
            <field name="state">code</field>
            <field name="code">model._check_student_count_notification()</field>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>