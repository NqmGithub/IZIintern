<odoo>
  <data>
    <record id="view_purchase_request_list" model="ir.ui.view">
      <field name="name">purchase.request.list</field>
      <field name="model">purchase.request</field>
      <field name="arch" type="xml">
        <list string="Purchase Requests">
          <field name="name"/>
          <field name="department_id" options="{'no_create': True}"/>
          <field name="requester_id" options="{'no_create': True}"/>
          <field name="description"/>
          <field name="date"/>
          <field name="state"/>
        </list>
      </field>
    </record>

    <record id="view_purchase_request_form" model="ir.ui.view">
      <field name="name">purchase.request.form</field>
      <field name="model">purchase.request</field>
      <field name="arch" type="xml">
        <form string="Purchase Request">
          <header>
            <button name="action_request_approve" 
                    string="Request Approval" 
                    type="object" 
                    class="btn-primary" 
                    invisible="state != 'draft'" 
                    groups="b2_purchase_request.group_purchase_request_user"/>
            <button name="action_back_to_draft" 
                    string="Back to Draft" 
                    type="object" 
                    class="btn-secondary" 
                    invisible="state != 'waiting'" 
                    groups="b2_purchase_request.group_purchase_request_user"/>
            <button name="action_approve"
                    string="Approve"
                    type="object"
                    class="btn-primary"
                    invisible="state != 'waiting'"
                    groups="b2_purchase_request.group_purchase_request_manager"/>
            <button name="action_reject_request"
                    string="Reject"
                    type="object"
                    class="btn-danger"
                    invisible="state != 'waiting'"
                    groups="b2_purchase_request.group_purchase_request_manager"/>

            <field name="state" widget="statusbar" readonly="1" options="{'clickable': True}"/>
          </header>
          <sheet>
            <div class="oe_title">
              <label for="name"/>
              <h1>
                  <field name="name" readonly="1"/>
              </h1>
            </div>
            <group>
              <group>
                <field name="department_id" options="{'no_create': True, 'no_open': True}"/>
                <field name="requester_id" options="{'no_create': True, 'no_open': True}"/>
                <field name="approver_id" options="{'no_create': True, 'no_open': True}"/>
                <field name="date"/>
                <field name="date_approved" invisible="1"/>
              </group>
              <group>
                <field name="description"/>
              </group>
            </group>
            <notebook>
              <page string="Lines" name="Purchase request lines">
                  <field name="request_line_ids" options="{'no_open': True}" readonly="state != 'draft'">
                  <list editable="bottom" create="state == 'draft'" delete="state == 'draft'">
                    <field name="product_id" options="{'no_create': True}"/>
                    <field name="uom_id" options="{'no_create': True}"/>
                    <field name="quantity"/>
                    <field name="quantity_approved" readonly="state != 'waiting'"/>
                    <field name="total" readonly="1"/>
                  </list>
                </field>
              </page>
            </notebook>
          </sheet>
        </form>
      </field>
    </record>

    <record id='action_purchase_request' model='ir.actions.act_window'>
      <field name='name'>Purchase Requests</field>
      <field name='res_model'>purchase.request</field>
      <field name='view_mode'>list,form</field>
    </record>

    <menuitem id="menu_purchase_request_root" 
          name="Purchase Requests" 
          parent="purchase.menu_purchase_root"
          sequence="10"/>
    <menuitem id="menu_purchase_request_action" 
          name="Purchase Requests" 
          parent="menu_purchase_request_root"
          action="action_purchase_request" 
          sequence="10"/>
  </data>
</odoo>
