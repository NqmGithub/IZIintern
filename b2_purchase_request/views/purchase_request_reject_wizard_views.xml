<odoo>
    <record id="view_purchase_request_rejection_form" model="ir.ui.view">
        <field name="name">purchase.request.rejection.form</field>
        <field name="model">purchase.request.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Reject Purchase Request">
                <sheet>
                    <h1>Enter reject reason:</h1>
                    <group>
                        <field name="reason" widget="textarea"/>
                    </group>
                    <footer>
                        <button name="action_reject" string="Confirm Rejection" type="object" class="btn-danger"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>
</odoo>